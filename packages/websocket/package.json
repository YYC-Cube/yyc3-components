{
  "name": "@yyc3/websocket",
  "version": "1.0.0",
  "description": "YYC3 WebSocket React Hooks - 完整的 WebSocket 连接管理",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "websocket",
    "react",
    "hooks",
    "realtime",
    "websocket-manager",
    "auto-reconnect"
  ],
  "author": "YYC³ Team",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
