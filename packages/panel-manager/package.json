{
  "name": "@yyc3/panel-manager",
  "version": "1.0.0",
  "description": "YYC3 Panel Manager - Unified panel state management and draggable layouts",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "yyc3",
    "panel",
    "layout",
    "draggable",
    "tabs"
  ],
  "author": "YanYuCloudCube Team",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.378.0",
    "motion": "^12.38.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
