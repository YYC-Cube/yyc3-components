{
  "name": "@yyc3/chat",
  "version": "1.0.0",
  "description": "YYC3 Chat React Components & Hooks - 聊天组件和持久化",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
