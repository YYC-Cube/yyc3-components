{
  "name": "@yyc3/types",
  "version": "1.0.0",
  "description": "YYC3可复用组件库 - 类型定义包",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "yyc3",
    "typescript",
    "types",
    "react"
  ],
  "author": "YYC3 Team",
  "license": "MIT",
  "homepage": "https://github.com/YYC-Cube/yyc3-components#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/yyc3-components.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/YYC-Cube/yyc3-components/issues"
  }
}
